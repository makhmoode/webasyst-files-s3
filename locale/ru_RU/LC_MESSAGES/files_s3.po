msgstr ""
"Project-Id-Version: files s3\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Language: ru_RU\n"

msgid "S3 server"
msgstr "S3-сервер"

msgid "Provides S3-compatible protocol access to Files app storages"
msgstr "Обеспечивает доступ к хранилищам приложения «Файлы» по протоколу S3"

msgid "Enable S3"
msgstr "Включить S3"

msgid "Server URL"
msgstr "URL сервера"

msgid "AWS region"
msgstr "Регион AWS"

msgid "Region string for S3 client configuration and Signature V4 (e.g. us-east-1)."
msgstr "Регион для настройки S3-клиента и Signature V4 (например, us-east-1)."

msgid "S3 server must be secured by a valid SSL certificate for production use."
msgstr "S3-сервер должен быть защищён действительным SSL-сертификатом для промышленного использования."

msgid "Use path-style S3 access in client configuration. Storage names are used as bucket names — use DNS-compatible lowercase names for best compatibility with S3 clients."
msgstr "Используйте path-style доступ в настройках S3-клиента. Имена хранилищ используются как имена bucket — для лучшей совместимости используйте строчные DNS-совместимые имена."

msgid "You need the settlement of Files to switch on S3."
msgstr "Для включения S3 необходимо поселение приложения «Файлы»."

msgid "S3 credentials"
msgstr "Учётные данные S3"

msgid "Endpoint"
msgstr "Endpoint"

msgid "Region"
msgstr "Регион"

msgid "Access key"
msgstr "Ключ доступа"

msgid "Secret key"
msgstr "Секретный ключ"

msgid "Show"
msgstr "Показать"

msgid "Hide"
msgstr "Скрыть"

msgid "Regenerate secret"
msgstr "Перегенерировать секрет"

msgid "S3 settlement URL is not configured. Ask your administrator to configure the S3 plugin."
msgstr "URL поселения S3 не настроен. Обратитесь к администратору для настройки плагина S3."

msgid "Regenerate secret key? Existing S3 clients will stop working until you update their configuration."
msgstr "Перегенерировать секретный ключ? Существующие S3-клиенты перестанут работать, пока вы не обновите их настройки."

msgid "Access denied"
msgstr "Доступ запрещён"
