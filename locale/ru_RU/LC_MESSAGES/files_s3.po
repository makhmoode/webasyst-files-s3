msgid "S3 Server"
msgstr "Сервер S3"

msgid "Provides S3-compatible protocol access to Files app storages"
msgstr "Обеспечивает доступ к хранилищам приложения «Файлы» по протоколу S3"

msgid "Enable S3"
msgstr "Включить S3"

msgid "Server URL"
msgstr "URL сервера"

msgid "Region"
msgstr "Регион"

msgid "Region string for S3 client configuration and Signature V4 (e.g. us-east-1)."
msgstr "Регион для настройки S3-клиента и Signature V4 (например, us-east-1)."

msgid "S3 Server must be secured by a valid SSL certificate for production use."
msgstr "Сервер S3 должен быть защищён действительным SSL-сертификатом для реального применения."

msgid "To enable S3, you need a dedicated domain or subdomain (for example, <code>%s</code>) with a root settlement of the Files app."
msgstr "Для включения S3 нужен выделенный домен или субдомен (например, <code>%s</code>) с поселением приложения «Файлы» в корне."

msgid "Use <a href=\"%s\">Site</a> to create new settlement."
msgstr "Создайте поселение в приложении <a href=\"%s\">Сайт</a>."

msgid "S3 credentials"
msgstr "Учётные данные S3"

msgid "Personal S3 settings"
msgstr "Личные настройки S3"

msgid "Use these credentials in S3 clients (Cyberduck, aws cli, rclone). The access key is your Webasyst login."
msgstr "Используйте эти учётные данные в S3-клиентах (Cyberduck, aws cli, rclone). Ключ доступа — ваш логин Webasyst."

msgid "On-demand source sync TTL"
msgstr "TTL синхронизации по требованию"

msgid "New secret key"
msgstr "Новый секретный ключ"

msgid "S3 connection settings"
msgstr "Настройки подключения S3"

msgid "S3 URL"
msgstr "URL S3"

msgid "S3 Access Key"
msgstr "Ключ доступа S3"

msgid "S3 Secret Access Key"
msgstr "Секретный ключ доступа S3"

msgid "Endpoint"
msgstr "Endpoint"

msgid "Access key"
msgstr "Ключ доступа"

msgid "Secret key"
msgstr "Секретный ключ"

msgid "Show"
msgstr "Показать"

msgid "Hide"
msgstr "Скрыть"

msgid "Regenerate secret"
msgstr "Перегенерировать секрет"

msgid "S3 settlement URL is not configured. Ask your administrator to configure the S3 plugin."
msgstr "URL поселения S3 не настроен. Обратитесь к администратору для настройки плагина S3."

msgid "Regenerate secret key? Existing S3 clients will stop working until you update their configuration."
msgstr "Перегенерировать секретный ключ? Существующие S3-клиенты перестанут работать, пока вы не обновите их настройки."

msgid "Access denied"
msgstr "Доступ запрещён"

msgid "Copy to clipboard"
msgstr "Копировать в буфер обмена"

msgid "Only a root settlement of the Files app can be used as S3 endpoint."
msgstr "В качестве S3 endpoint можно использовать только корневое поселение приложения «Файлы»."

msgid "Users S3 secrets"
msgstr "S3-секреты пользователей"

msgid "Manage S3 secret access keys for users who have access to the Files app. The access key is the user login."
msgstr "Управление секретными ключами S3 для пользователей с доступом к приложению «Файлы». Ключ доступа — логин пользователя."

msgid "User"
msgstr "Пользователь"

msgid "not set"
msgstr "не задан"

msgid "Configured"
msgstr "Настроен"

msgid "Not configured"
msgstr "Не настроен"

msgid "Generate"
msgstr "Сгенерировать"

msgid "Regenerate"
msgstr "Перегенерировать"

msgid "Delete"
msgstr "Удалить"

msgid "No users with access to the Files app."
msgstr "Нет пользователей с доступом к приложению «Файлы»."

msgid "User not found or has no access to Files app"
msgstr "Пользователь не найден или не имеет доступа к приложению «Файлы»"

msgid "Secret key already exists"
msgstr "Секретный ключ уже существует"

msgid "Secret key is not configured"
msgstr "Секретный ключ не настроен"

msgid "Invalid operation"
msgstr "Недопустимая операция"

msgid "Delete secret key for this user? Existing S3 clients configured with this key will stop working."
msgstr "Удалить секретный ключ для этого пользователя? S3-клиенты, настроенные с этим ключом, перестанут работать."

msgid "Regenerate secret key for this user? Existing S3 clients will stop working until their configuration is updated."
msgstr "Перегенерировать секретный ключ для этого пользователя? S3-клиенты перестанут работать, пока их настройки не будут обновлены."

msgid "OK"
msgstr "OK"

msgid "Upload size limit"
msgstr "Лимит размера загрузки"

msgid "Current maximum upload size:"
msgstr "Текущий максимальный размер загружаемого файла:"

msgid "The effective limit is the smaller of PHP <code>upload_max_filesize</code> and <code>post_max_size</code>. S3 PutObject and each multipart UploadPart must fit within this limit (and within the web server body size limit)."
msgstr "Фактический лимит — меньшее из значений PHP <code>upload_max_filesize</code> и <code>post_max_size</code>. PutObject и каждая часть multipart UploadPart должны укладываться в этот лимит (и в лимит размера тела запроса веб-сервера)."

msgid "To increase the limit, raise <code>upload_max_filesize</code> and <code>post_max_size</code> in <code>%s</code> (or in the PHP-FPM pool / <code>.user.ini</code>). Keep <code>post_max_size</code> ≥ <code>upload_max_filesize</code>, restart PHP, and also check the web server limit (e.g. nginx <code>client_max_body_size</code>)."
msgstr "Чтобы увеличить лимит, поднимите <code>upload_max_filesize</code> и <code>post_max_size</code> в <code>%s</code> (или в пуле PHP-FPM / <code>.user.ini</code>). Значение <code>post_max_size</code> должно быть не меньше <code>upload_max_filesize</code>, затем перезапустите PHP и проверьте лимит веб-сервера (например, nginx <code>client_max_body_size</code>)."

msgid "To increase the limit, raise <code>upload_max_filesize</code> and <code>post_max_size</code> in php.ini (or in the PHP-FPM pool / .user.ini). Keep <code>post_max_size</code> ≥ <code>upload_max_filesize</code>, restart PHP, and also check the web server limit (e.g. nginx <code>client_max_body_size</code>)."
msgstr "Чтобы увеличить лимит, поднимите <code>upload_max_filesize</code> и <code>post_max_size</code> в php.ini (или в пуле PHP-FPM / .user.ini). Значение <code>post_max_size</code> должно быть не меньше <code>upload_max_filesize</code>, затем перезапустите PHP и проверьте лимит веб-сервера (например, nginx <code>client_max_body_size</code>)."

msgid "Available buckets"
msgstr "Доступные бакеты"

msgid "Use path-style S3 access in client configuration."
msgstr "Используйте path-style доступ в настройках S3-клиента."

msgid "Storage names are used as bucket names — use DNS-compatible lowercase names for best compatibility with S3 clients."
msgstr "Названия хранилищ (корневых папок) используются как имена бакетов — для лучшей совместимости используйте строчные DNS-совместимые имена."

msgid "Storage names are used as S3 bucket names."
msgstr "Названия хранилищ (корневых папок) используются как имена S3 бакетов."

msgid "Use path-style requests, for example:"
msgstr "Используйте path-style запросы, например:"

msgid "No storages are available as S3 buckets."
msgstr "Нет хранилищ, доступных как S3 бакеты."

msgid "Personal"
msgstr "Персональное"

msgid "Shared with any backend user"
msgstr "Доступно всем пользователям бекенда"

msgid "Limited access"
msgstr "Ограниченный доступ"

msgid "name is not DNS-compatible; some S3 clients may require path-style access"
msgstr "имя не DNS-совместимо; для некоторых S3-клиентов может быть недоступным"
